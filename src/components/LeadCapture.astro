---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  formAction?: string;
  variant?: 'form' | 'mailto' | 'booking';
  showPhone?: boolean;
}

const {
  eyebrow = 'Get Started',
  title = 'Ready to Train With Us?',
  description,
  formAction = 'mailto:info@valkyriearmstraining.com',
  variant = 'mailto',
  showPhone = true,
} = Astro.props;
---

<section class="lead-capture section" id="lead-capture">
  <div class="container">
    <div class="lead-inner">
      <div class="lead-text reveal">
        <span class="eyebrow">{eyebrow}</span>
        <h2 class="lead-title">{title}</h2>
        {description && <p class="lead-desc">{description}</p>}

        {showPhone && (
          <div class="lead-quick-contact">
            <a href="tel:208-815-8592" class="lead-phone">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <span>Call CheRee: 208-815-8592</span>
            </a>
            <a href="tel:208-813-8780" class="lead-phone">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <span>Call Dez: 208-813-8780</span>
            </a>
          </div>
        )}
      </div>

      <div class="lead-form-wrap reveal delay-200">
        <form class="lead-form" action={formAction} method={variant === 'mailto' ? 'get' : 'post'}>
          <div class="form-group">
            <label for="lead-name" class="form-label">Your Name</label>
            <input type="text" id="lead-name" name="name" class="form-input" placeholder="Jane Smith" required />
          </div>
          <div class="form-group">
            <label for="lead-email" class="form-label">Email Address</label>
            <input type="email" id="lead-email" name="email" class="form-input" placeholder="jane@example.com" required />
          </div>
          <div class="form-group">
            <label for="lead-phone" class="form-label">Phone (optional)</label>
            <input type="tel" id="lead-phone" name="phone" class="form-input" placeholder="(208) 555-0123" />
          </div>
          <div class="form-group">
            <label for="lead-message" class="form-label">How can we help?</label>
            <textarea id="lead-message" name="message" class="form-input form-textarea" placeholder="I'm interested in learning about your classes..." rows="4"></textarea>
          </div>
          <button type="submit" class="btn btn-primary form-submit">
            Send Message
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .lead-capture {
    background: var(--pwp-color-background-elevated);
    border-radius: var(--pwp-radius-xl);
    margin-left: var(--pwp-container-padding);
    margin-right: var(--pwp-container-padding);
    max-width: var(--pwp-container-max);
    margin-left: auto;
    margin-right: auto;
    position: relative;
    overflow: hidden;
  }

  .lead-capture::before {
    content: '';
    position: absolute;
    top: -200px;
    right: -200px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, var(--pwp-color-accent-primary-muted), transparent 70%);
    pointer-events: none;
  }

  .lead-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--pwp-space-12);
    align-items: start;
    position: relative;
  }

  @media (max-width: 768px) {
    .lead-inner {
      grid-template-columns: 1fr;
      gap: var(--pwp-space-8);
    }
  }

  .lead-text {
    display: flex;
    flex-direction: column;
    gap: var(--pwp-space-4);
  }

  .lead-title {
    font-size: var(--pwp-font-size-3xl);
  }

  .lead-desc {
    font-size: var(--pwp-font-size-base);
    color: var(--pwp-color-text-secondary);
    line-height: var(--pwp-line-height-relaxed);
  }

  .lead-quick-contact {
    display: flex;
    flex-direction: column;
    gap: var(--pwp-space-3);
    margin-top: var(--pwp-space-4);
    padding: var(--pwp-space-6);
    background: var(--pwp-color-surface-card);
    border-radius: var(--pwp-radius-lg);
    border: 1px solid var(--pwp-color-border-subtle);
  }

  .lead-phone {
    display: flex;
    align-items: center;
    gap: var(--pwp-space-3);
    color: var(--pwp-color-text-secondary);
    text-decoration: none;
    font-weight: var(--pwp-font-weight-medium);
    transition: color var(--pwp-motion-fast) var(--pwp-easing-default);
  }

  .lead-phone:hover {
    color: var(--pwp-color-accent-gold);
  }

  .lead-phone svg {
    color: var(--pwp-color-accent-gold);
  }

  /* Form */
  .lead-form {
    display: flex;
    flex-direction: column;
    gap: var(--pwp-space-5);
    background: var(--pwp-color-surface-card);
    padding: var(--pwp-space-8);
    border-radius: var(--pwp-radius-lg);
    border: 1px solid var(--pwp-color-border-subtle);
  }

  .form-label {
    display: block;
    font-size: var(--pwp-font-size-sm);
    font-weight: var(--pwp-font-weight-medium);
    color: var(--pwp-color-text-secondary);
    margin-bottom: var(--pwp-space-2);
  }

  .form-input {
    width: 100%;
    padding: var(--pwp-space-3) var(--pwp-space-4);
    background: var(--pwp-color-background-page);
    border: 1px solid var(--pwp-color-border-default);
    border-radius: var(--pwp-radius-md);
    color: var(--pwp-color-text-primary);
    font-family: var(--pwp-font-family-body);
    font-size: var(--pwp-font-size-base);
    transition: all var(--pwp-motion-fast) var(--pwp-easing-default);
    outline: none;
  }

  .form-input::placeholder {
    color: var(--pwp-color-text-tertiary);
  }

  .form-input:focus {
    border-color: var(--pwp-color-accent-primary);
    box-shadow: 0 0 0 3px var(--pwp-color-accent-primary-muted);
  }

  .form-textarea {
    resize: vertical;
    min-height: 100px;
  }

  .form-submit {
    width: 100%;
    padding: var(--pwp-space-4);
    font-size: var(--pwp-font-size-base);
    margin-top: var(--pwp-space-2);
  }
</style>
