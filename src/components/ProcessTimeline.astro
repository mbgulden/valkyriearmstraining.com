---
interface TimelineStep {
  number: string;
  title: string;
  description: string;
  icon?: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  steps: TimelineStep[];
}

const { eyebrow, title, steps } = Astro.props;
---

<section class="timeline section">
  <div class="container">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h2 class="timeline-heading reveal">{title}</h2>
    <div class="timeline-track">
      {steps.map((step, i) => (
        <div class={`timeline-step reveal delay-${(i + 1) * 100}`}>
          <div class="timeline-marker">
            <span class="timeline-number">{step.number || String(i + 1).padStart(2, '0')}</span>
            {i < steps.length - 1 && <div class="timeline-line" />}
          </div>
          <div class="timeline-content">
            {step.icon && <span class="timeline-icon">{step.icon}</span>}
            <h3 class="timeline-title">{step.title}</h3>
            <p class="timeline-desc">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline-heading {
    margin-bottom: var(--pwp-space-12);
    font-size: var(--pwp-font-size-3xl);
  }

  .timeline-track {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 700px;
  }

  .timeline-step {
    display: flex;
    gap: var(--pwp-space-6);
    position: relative;
  }

  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }

  .timeline-number {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--pwp-color-accent-primary), #7B4FBF);
    color: var(--pwp-color-text-primary);
    font-family: var(--pwp-font-family-heading);
    font-weight: var(--pwp-font-weight-bold);
    font-size: var(--pwp-font-size-lg);
    border-radius: var(--pwp-radius-full);
    box-shadow: var(--pwp-shadow-glow-purple);
    position: relative;
    z-index: 1;
  }

  .timeline-line {
    width: 2px;
    flex-grow: 1;
    min-height: 40px;
    background: linear-gradient(to bottom, var(--pwp-color-accent-primary), var(--pwp-color-border-subtle));
  }

  .timeline-content {
    padding-bottom: var(--pwp-space-10);
    padding-top: var(--pwp-space-2);
  }

  .timeline-icon {
    font-size: 1.5rem;
    margin-bottom: var(--pwp-space-2);
    display: block;
  }

  .timeline-title {
    font-size: var(--pwp-font-size-xl);
    margin-bottom: var(--pwp-space-2);
    color: var(--pwp-color-text-primary);
  }

  .timeline-desc {
    font-size: var(--pwp-font-size-base);
    color: var(--pwp-color-text-secondary);
    line-height: var(--pwp-line-height-relaxed);
  }
</style>
