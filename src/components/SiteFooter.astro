---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: 'About Us', href: '/about' },
  { label: 'Class Directory', href: '/classes' },
  { label: 'Meet the Instructors', href: '/instructors' },
  { label: 'FAQ', href: '/faq' },
  { label: 'Simulator Rental', href: '/simulator' },
  { label: 'Contact Us', href: '/contact' },
];

const serviceAreas = [
  { label: 'Meridian', href: '/training/meridian' },
  { label: 'Boise', href: '/training/boise' },
  { label: 'Eagle', href: '/training/eagle' },
  { label: 'Nampa', href: '/training/nampa' },
  { label: 'Kuna', href: '/training/kuna' },
  { label: 'Caldwell', href: '/training/caldwell' },
];
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand column -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="Valkyrie Arms Training">
          <img src="/images/logo-full.png" alt="Valkyrie Arms Training" class="footer-logo-image" width="160" height="45" />
        </a>
        <p class="footer-mission">
          Empowering women through preparedness, education, and practical skills
          to confidently protect themselves, their families, and their communities.
        </p>
        <div class="footer-contact-info">
          <a href="tel:208-815-8592" class="footer-contact-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            208-815-8592
          </a>
          <a href="mailto:info@valkyriearmstraining.com" class="footer-contact-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            info@valkyriearmstraining.com
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="footer-col">
        <h4 class="footer-col-title">Quick Links</h4>
        <nav aria-label="Footer quick links">
          {quickLinks.map(link => (
            <a href={link.href} class="footer-link">{link.label}</a>
          ))}
        </nav>
      </div>

      <!-- Service Areas -->
      <div class="footer-col">
        <h4 class="footer-col-title">Service Areas</h4>
        <nav aria-label="Service areas">
          {serviceAreas.map(area => (
            <a href={area.href} class="footer-link">{area.label}, ID</a>
          ))}
        </nav>
      </div>

      <!-- Location -->
      <div class="footer-col">
        <h4 class="footer-col-title">Visit Us</h4>
        <address class="footer-address">
          <p>272 SW 5th #400</p>
          <p>Meridian, ID 83642</p>
        </address>
        <p class="footer-hours">
          <strong>Office Hours:</strong><br />
          10:00 AM – 7:00 PM<br />
          <span class="footer-hours-note">Training by appointment</span>
        </p>
        <div class="footer-social">
          <a href="https://www.instagram.com/valkyriearmstraining/" target="_blank" rel="noopener noreferrer" aria-label="Follow us on Instagram" class="social-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            <span>Instagram</span>
          </a>
          <a href="https://www.facebook.com/people/Valkyrie-Arms-Training/61590237959110/" target="_blank" rel="noopener noreferrer" aria-label="Follow us on Facebook" class="social-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            <span>Facebook</span>
          </a>
        </div>
      </div>
    </div>

    <hr class="divider" />

    <div class="footer-bottom">
      <p class="footer-copyright">
        &copy; {currentYear} Valkyrie Arms Training. All rights reserved.
      </p>
      <p class="footer-legal">
        <a href="/privacy">Privacy Policy</a>
        <span class="footer-legal-sep">·</span>
        <a href="/terms">Terms of Service</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--pwp-color-background-elevated);
    border-top: 1px solid var(--pwp-color-border-subtle);
    padding-top: var(--pwp-space-16);
    padding-bottom: var(--pwp-space-8);
    margin-top: var(--pwp-space-24);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: var(--pwp-space-10);
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--pwp-space-8);
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--pwp-space-8);
    }
  }

  /* Brand */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--pwp-space-3);
    text-decoration: none;
    color: var(--pwp-color-text-primary);
    margin-bottom: var(--pwp-space-4);
  }

  .footer-logo-image {
    height: 45px;
    width: auto;
    object-fit: contain;
    border-radius: var(--pwp-radius-sm);
    transition: opacity var(--pwp-motion-fast) var(--pwp-easing-default);
  }

  .footer-logo:hover .footer-logo-image {
    opacity: 0.85;
  }

  .footer-mission {
    font-size: var(--pwp-font-size-sm);
    color: var(--pwp-color-text-tertiary);
    line-height: var(--pwp-line-height-relaxed);
    margin-bottom: var(--pwp-space-6);
    max-width: 35ch;
  }

  .footer-contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--pwp-space-2);
  }

  .footer-contact-link {
    display: flex;
    align-items: center;
    gap: var(--pwp-space-2);
    font-size: var(--pwp-font-size-sm);
    color: var(--pwp-color-text-secondary);
    text-decoration: none;
    transition: color var(--pwp-motion-fast) var(--pwp-easing-default);
  }

  .footer-contact-link:hover {
    color: var(--pwp-color-accent-primary);
  }

  .footer-contact-link svg {
    color: var(--pwp-color-accent-primary);
    flex-shrink: 0;
  }

  /* Columns */
  .footer-col-title {
    font-family: var(--pwp-font-family-heading);
    font-size: var(--pwp-font-size-sm);
    font-weight: var(--pwp-font-weight-semibold);
    color: var(--pwp-color-accent-gold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--pwp-space-4);
  }

  .footer-col nav {
    display: flex;
    flex-direction: column;
    gap: var(--pwp-space-2);
  }

  .footer-link {
    font-size: var(--pwp-font-size-sm);
    color: var(--pwp-color-text-secondary);
    text-decoration: none;
    transition: all var(--pwp-motion-fast) var(--pwp-easing-default);
    padding: var(--pwp-space-1) 0;
  }

  .footer-link:hover {
    color: var(--pwp-color-text-primary);
    transform: translateX(4px);
  }

  /* Address */
  .footer-address {
    font-style: normal;
    font-size: var(--pwp-font-size-sm);
    color: var(--pwp-color-text-secondary);
    line-height: var(--pwp-line-height-relaxed);
    margin-bottom: var(--pwp-space-4);
  }

  .footer-address p {
    color: var(--pwp-color-text-secondary);
    font-size: var(--pwp-font-size-sm);
  }

  .footer-hours {
    font-size: var(--pwp-font-size-sm);
    color: var(--pwp-color-text-secondary);
    line-height: var(--pwp-line-height-relaxed);
  }

  .footer-hours strong {
    color: var(--pwp-color-text-primary);
  }

  .footer-hours-note {
    font-size: var(--pwp-font-size-xs);
    color: var(--pwp-color-text-tertiary);
    font-style: italic;
  }

  /* Bottom */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--pwp-space-4);
  }

  .footer-copyright {
    font-size: var(--pwp-font-size-xs);
    color: var(--pwp-color-text-tertiary);
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: var(--pwp-space-2);
    font-size: var(--pwp-font-size-xs);
  }

  .footer-legal a {
    color: var(--pwp-color-text-tertiary);
    text-decoration: none;
    transition: color var(--pwp-motion-fast) var(--pwp-easing-default);
  }

  .footer-legal a:hover {
    color: var(--pwp-color-accent-primary);
  }

  .footer-legal-sep {
    color: var(--pwp-color-text-tertiary);
  }

  /* Social */
  .footer-social {
    display: flex;
    gap: var(--pwp-space-3);
    margin-top: var(--pwp-space-4);
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: var(--pwp-space-2);
    font-size: var(--pwp-font-size-sm);
    color: var(--pwp-color-text-secondary);
    text-decoration: none;
    padding: var(--pwp-space-2) var(--pwp-space-3);
    border-radius: var(--pwp-radius-md);
    border: 1px solid var(--pwp-color-border-subtle);
    transition: all var(--pwp-motion-fast) var(--pwp-easing-default);
  }

  .social-link:hover {
    color: var(--pwp-color-accent-primary);
    border-color: var(--pwp-color-border-default);
    background: var(--pwp-color-accent-primary-muted);
  }

  .social-link svg {
    flex-shrink: 0;
  }
</style>
