---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SplitSection from '../../components/SplitSection.astro';
import CardGrid from '../../components/CardGrid.astro';
import FAQ from '../../components/FAQ.astro';
import LeadCapture from '../../components/LeadCapture.astro';

const city = 'Caldwell';

const classes = [
  { title: 'Idaho Enhanced Concealed Carry', description: 'Comprehensive concealed carry course covering Idaho firearm laws, proper technique, and defensive decision-making.', href: '/classes/concealed-carry', icon: '🎯' },
  { title: 'Basic Handgun Fundamentals', description: 'Perfect for beginners. Learn firearm safety, proper grip, stance, and live fire basics in a supportive environment.', href: '/classes/basic-handgun', icon: '🔫' },
  { title: 'Self-Defense Basics', description: 'Practical self-defense skills including situational awareness, non-lethal options, and personal safety strategies.', href: '/classes/self-defense', icon: '🛡️' },
];

const faqItems = [
  { question: `I'm in ${city}. Is Valkyrie close enough for regular training?`, answer: `Yes! Our Meridian facility at 272 SW 5th #400 is easily accessible from ${city} via I-84. Many of our students come from across Canyon County, and our flexible scheduling makes it convenient to train regularly.` },
  { question: "I've never touched a firearm before. Is this class for me?", answer: "Absolutely. Many of our students have little to no prior experience. Our classes are designed for everyday women, and we meet you where you are. No experience is required, and no question is a bad question." },
  { question: "I'm nervous or intimidated. What if I don't know anything?", answer: "You're exactly who we designed Valkyrie for. We understand that trying something new can feel intimidating, especially when it comes to personal safety and firearms. Our goal is to create a welcoming, supportive, and judgment-free environment where women can learn at their own pace and build confidence step by step." },
];

const jsonLd = { "@context": "https://schema.org", "@type": "LocalBusiness", "name": "Valkyrie Arms Training", "description": `Women's firearms and self-defense training serving ${city}, Idaho.`, "url": `https://valkyriearmstraining.com/training/caldwell`, "telephone": ["208-815-8592", "208-813-8780"], "email": "info@valkyriearmstraining.com", "address": { "@type": "PostalAddress", "streetAddress": "272 SW 5th #400", "addressLocality": "Meridian", "addressRegion": "ID", "postalCode": "83642", "addressCountry": "US" }, "areaServed": { "@type": "City", "name": city, "containedInPlace": { "@type": "State", "name": "Idaho" } } };
---

<BaseLayout title={`Women's Firearms Training in ${city}, Idaho`} description={`Women's firearms and self-defense training for ${city}, Idaho. Valkyrie Arms Training — expert-led, women-only classes serving Canyon County and the Treasure Valley.`} jsonLd={jsonLd}>
  <Hero variant="local-seo" eyebrow={`Serving ${city}, Idaho`} title={`Women's Firearms & Self-Defense Training for ${city}`} description={`${city} women — build confidence and preparedness with Valkyrie Arms Training. Our women-only facility in Meridian is just a short drive from ${city}, offering a safe, supportive space for women of all experience levels.`} image="/images/hero-range-action.jpg" imageAlt={`Women's training serving ${city}, Idaho`} primaryCTA={{ label: 'View Classes', href: '/classes' }} secondaryCTA={{ label: 'Contact Us', href: '/contact' }} />

  <SplitSection eyebrow="Our Promise" title={`Accessible Training for ${city} Women`} description="Personal safety and preparedness should not be limited by age, background, experience, or financial circumstances. Every woman is welcome at Valkyrie, whether a native Idahoan who grew up around firearms, or someone completely new to personal safety education." image="/images/team-partnership.jpg" imageAlt="Valkyrie team" items={['Women-only, judgment-free environment', 'Expert female instructors', 'No prior experience required', 'Firearms and non-lethal options covered', 'Easy drive from Caldwell via I-84']} />

  <section class="section"><div class="container"><span class="eyebrow">Classes</span><h2 class="section-heading reveal">Classes for {city} Women</h2><div class="reveal delay-100" style="margin-top: var(--pwp-space-8);"><CardGrid variant="3-up" items={classes} /></div></div></section>

  <section class="section"><div class="container"><FAQ title={`Questions from ${city} Students`} eyebrow="FAQ" items={faqItems} /></div></section>

  <LeadCapture eyebrow={`${city} Training`} title={`Ready to Begin?`} description={`Women from ${city} and across Canyon County are building confidence with Valkyrie. Contact us today.`} />
</BaseLayout>
