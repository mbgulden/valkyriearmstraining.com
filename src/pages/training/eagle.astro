---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SplitSection from '../../components/SplitSection.astro';
import CardGrid from '../../components/CardGrid.astro';
import FAQ from '../../components/FAQ.astro';
import LeadCapture from '../../components/LeadCapture.astro';

const city = 'Eagle';

const classes = [
  { title: 'Idaho Enhanced Concealed Carry', description: 'Comprehensive concealed carry course covering Idaho firearm laws, proper technique, and defensive decision-making.', href: '/classes/concealed-carry', icon: '🎯' },
  { title: 'Basic Handgun Fundamentals', description: 'Perfect for beginners. Learn firearm safety, proper grip, stance, and live fire basics in a supportive environment.', href: '/classes/basic-handgun', icon: '🔫' },
  { title: 'Self-Defense Basics', description: 'Practical self-defense skills including situational awareness, non-lethal options, and personal safety strategies.', href: '/classes/self-defense', icon: '🛡️' },
];

const faqItems = [
  { question: `I live in ${city}. How far is your training facility?`, answer: `Our training facility at 272 SW 5th #400, Meridian, ID 83642 is a short drive from ${city} — right in the heart of the Treasure Valley. Easy access makes it convenient for all ${city} residents.` },
  { question: "I've never touched a firearm before. Is this class for me?", answer: "Absolutely. Many of our students have little to no prior experience. Our classes are designed for everyday women, and we meet you where you are. No experience is required, and no question is a bad question." },
  { question: "Do I have to own a firearm to take your classes?", answer: "Not at all. Valkyrie is about preparedness, confidence, and personal safety. While we offer firearms training, we also teach situational awareness, non-lethal defense options, self-defense, medical preparedness, and other practical skills. Whether you choose to carry a firearm or not, our goal is to help you feel more capable and prepared." },
];

const jsonLd = { "@context": "https://schema.org", "@type": "LocalBusiness", "name": "Valkyrie Arms Training", "description": `Women's firearms and self-defense training serving ${city}, Idaho.`, "url": `https://valkyriearmstraining.com/training/eagle`, "telephone": ["208-815-8592", "208-813-8780"], "email": "info@valkyriearmstraining.com", "address": { "@type": "PostalAddress", "streetAddress": "272 SW 5th #400", "addressLocality": "Meridian", "addressRegion": "ID", "postalCode": "83642", "addressCountry": "US" }, "areaServed": { "@type": "City", "name": city, "containedInPlace": { "@type": "State", "name": "Idaho" } } };
---

<BaseLayout title={`Women's Firearms Training in ${city}, Idaho`} description={`Women's firearms and self-defense training for ${city}, Idaho women. Expert-led, women-only classes at Valkyrie Arms Training in the Treasure Valley.`} jsonLd={jsonLd}>
  <Hero variant="local-seo" eyebrow={`Serving ${city}, Idaho`} title={`Women's Self-Defense & Firearms Training for ${city} Residents`} description={`${city} women deserve to feel capable, confident, and prepared. Valkyrie Arms Training offers expert-led, women-only classes just minutes from ${city} in our Meridian training facility.`} image="/images/instructor-shooting.jpg" imageAlt={`Women's firearms training for ${city}, Idaho`} primaryCTA={{ label: 'View Classes', href: '/classes' }} secondaryCTA={{ label: 'Contact Us', href: '/contact' }} />

  <SplitSection eyebrow="Our Approach" title={`Training Designed for ${city} Women`} description="Women learn differently. Most of us want to know the 'why' and the 'how' something works. Our goal is that a firearm for you will become a tool that you feel comfortable with — just like your cell phone." image="/images/hands-on-training.jpg" imageAlt="Hands-on firearms training" items={['Women-only, judgment-free environment', 'Expert female instructors', 'Beginner-friendly — no experience needed', 'Covers firearms and non-lethal options', 'Conveniently located near Eagle']} />

  <section class="section"><div class="container"><span class="eyebrow">Classes</span><h2 class="section-heading reveal">Available Training for {city} Women</h2><div class="reveal delay-100" style="margin-top: var(--pwp-space-8);"><CardGrid variant="3-up" items={classes} /></div></div></section>

  <section class="section"><div class="container"><FAQ title={`Questions from ${city} Students`} eyebrow="FAQ" items={faqItems} /></div></section>

  <LeadCapture eyebrow={`${city} Training`} title={`Start Your Training Journey`} description={`Join ${city} women who are building confidence and preparedness. Reach out today to learn about our upcoming classes.`} />
</BaseLayout>
