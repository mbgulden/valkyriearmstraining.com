---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SplitSection from '../../components/SplitSection.astro';
import CardGrid from '../../components/CardGrid.astro';
import LeadCapture from '../../components/LeadCapture.astro';
---

<BaseLayout
  title="Self-Defense Basics for Women"
  description="Women's self-defense class in Meridian, ID. Not just firearms — learn non-lethal options, situational awareness, de-escalation, and practical self-defense skills."
>
  <Hero
    variant="service-detail"
    eyebrow="Classes"
    title="Self-Defense Basics"
    description="Self-defense is more than firearms. Whether you choose to carry a firearm or not, every woman deserves to feel prepared, confident, and capable of protecting herself and the people she loves."
    image="/images/team-partnership.jpg"
    imageAlt="Valkyrie Arms Training team together"
    primaryCTA={{ label: 'Register Now', href: '#lead-capture' }}
    secondaryCTA={{ label: 'Call Us', href: 'tel:208-815-8592' }}
  />

  <SplitSection
    eyebrow="Beyond Firearms"
    title="A Complete Approach to Personal Safety"
    description="This class goes beyond firearms to give you practical, real-world self-defense skills you can use every day. We believe in preparedness in all its forms — because being prepared isn't just about what you carry, it's about how you think."
    image="/images/training-scene.jpg"
    imageAlt="Training scene"
    items={[
      'Situational awareness and threat recognition',
      'De-escalation techniques',
      'Non-lethal self-defense options',
      'Personal safety planning',
      'Building confidence through preparedness',
    ]}
  />

  <div class="section container">
    <div class="reveal">
      <span class="eyebrow">Our Philosophy</span>
      <h2>Empowerment Through Preparedness</h2>
    </div>
    <CardGrid
      variant="icon-card"
      items={[
        {
          title: 'Awareness',
          description: 'Learn to read your environment and identify potential threats before they become dangerous situations.',
          icon: '👁️',
        },
        {
          title: 'De-Escalation',
          description: 'Develop verbal and non-verbal techniques to defuse confrontational situations safely.',
          icon: '🤝',
        },
        {
          title: 'Non-Lethal Options',
          description: 'Explore the range of non-lethal self-defense tools and techniques available to you.',
          icon: '🛡️',
        },
      ]}
    />
  </div>

  <SplitSection
    eyebrow="For Every Woman"
    title="No Experience Required"
    description="You don't need any prior experience or physical fitness level to participate. Every woman deserves access to self-defense education, regardless of background, ability, or experience level. We adapt our instruction to meet you where you are."
    image="/images/hero-range-action.jpg"
    imageAlt="Women learning at outdoor range"
    reversed={true}
  />

  <div class="section container">
    <div class="reveal" style="text-align: center; max-width: 600px; margin: 0 auto;">
      <span class="eyebrow">Pricing & Schedule</span>
      <h2>Ready to Get Started?</h2>
      <p style="color: var(--pwp-color-text-secondary); line-height: var(--pwp-line-height-relaxed);">
        Contact us for current pricing and upcoming class dates. Classes are available in Meridian and the surrounding Treasure Valley area, including Boise, Eagle, Nampa, Kuna, and Caldwell.
      </p>
    </div>
  </div>

  <LeadCapture
    eyebrow="Enroll Today"
    title="Sign Up for Self-Defense Basics"
    description="Fill out the form below and we'll get back to you with available class dates and all the details you need."
  />
</BaseLayout>
