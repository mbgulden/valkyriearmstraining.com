---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SplitSection from '../../components/SplitSection.astro';
import CardGrid from '../../components/CardGrid.astro';
import LeadCapture from '../../components/LeadCapture.astro';
---

<BaseLayout
  title="Medical Preparedness Training for Women"
  description="Women's medical preparedness class in Meridian, ID. Learn basic first aid, trauma response, and emergency preparedness skills for everyday situations."
>
  <Hero
    variant="service-detail"
    eyebrow="Classes"
    title="Medical Preparedness Training"
    description="Preparedness extends beyond self-defense. Learn basic first aid, trauma response, and emergency skills that could save a life — including your own. Be ready for the unexpected."
    image="/images/team-partnership.jpg"
    imageAlt="Valkyrie Arms Training team"
    primaryCTA={{ label: 'Register Now', href: '#lead-capture' }}
    secondaryCTA={{ label: 'Call Us', href: 'tel:208-815-8592' }}
  />

  <SplitSection
    eyebrow="What You'll Learn"
    title="Be Prepared for the Unexpected"
    description="From everyday injuries to emergency situations, this class gives you practical medical knowledge and hands-on skills you can use to help yourself, your family, and your community."
    image="/images/hands-on-training.jpg"
    imageAlt="Hands-on training close-up"
    items={[
      'Basic first aid fundamentals',
      'Trauma response and wound care',
      'Emergency preparedness planning',
      'When and how to call for help',
      'Building a personal first aid kit',
    ]}
  />

  <div class="section container">
    <div class="reveal">
      <span class="eyebrow">Areas of Focus</span>
      <h2>Practical Skills for Real Situations</h2>
    </div>
    <CardGrid
      variant="icon-card"
      items={[
        {
          title: 'First Aid Basics',
          description: 'Learn essential first aid skills for common injuries and emergencies you may encounter in daily life.',
          icon: '🩹',
        },
        {
          title: 'Trauma Response',
          description: 'Understand how to respond to serious injuries, control bleeding, and stabilize a situation until help arrives.',
          icon: '🚑',
        },
        {
          title: 'Emergency Planning',
          description: 'Build an emergency preparedness plan for your home and family so you know exactly what to do when the unexpected happens.',
          icon: '📋',
        },
      ]}
    />
  </div>

  <SplitSection
    eyebrow="Preparedness Is a Lifestyle"
    title="More Than Just a Class"
    description="Medical preparedness is a core part of the Valkyrie philosophy. We believe every woman deserves to feel prepared, confident, and capable — and that includes knowing how to respond when someone needs help. No prior medical training is required."
    image="/images/training-scene.jpg"
    imageAlt="Training scene"
    reversed={true}
  />

  <div class="section container">
    <div class="reveal" style="text-align: center; max-width: 600px; margin: 0 auto;">
      <span class="eyebrow">Pricing & Schedule</span>
      <h2>Ready to Get Started?</h2>
      <p style="color: var(--pwp-color-text-secondary); line-height: var(--pwp-line-height-relaxed);">
        Contact us for current pricing and upcoming class dates. Classes are available in Meridian and the surrounding Treasure Valley area, including Boise, Eagle, Nampa, Kuna, and Caldwell.
      </p>
    </div>
  </div>

  <LeadCapture
    eyebrow="Enroll Today"
    title="Sign Up for Medical Preparedness"
    description="Fill out the form below and we'll get back to you with available class dates and all the details you need."
  />
</BaseLayout>
