---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SplitSection from '../../components/SplitSection.astro';
import ProcessTimeline from '../../components/ProcessTimeline.astro';
import LeadCapture from '../../components/LeadCapture.astro';
---

<BaseLayout
  title="Situational Awareness Training for Women"
  description="Women's situational awareness class in Meridian, ID. Learn to read environments, identify threats, and avoid dangerous situations before they escalate."
>
  <Hero
    variant="service-detail"
    eyebrow="Classes"
    title="Situational Awareness Training"
    description="The best self-defense is avoiding danger altogether. Learn to read your environment, identify potential threats, and make decisions that keep you and your loved ones safe — before a situation ever escalates."
    image="/images/training-scene.jpg"
    imageAlt="Women in training"
    primaryCTA={{ label: 'Register Now', href: '#lead-capture' }}
    secondaryCTA={{ label: 'Call Us', href: 'tel:208-815-8592' }}
  />

  <SplitSection
    eyebrow="What You'll Learn"
    title="See What Others Miss"
    description="Situational awareness is a skill that can be learned and practiced. This class teaches you to move through your daily life with greater confidence and alertness — not paranoia, but preparedness."
    image="/images/hero-range-action.jpg"
    imageAlt="Women at outdoor training range"
    items={[
      'Reading environments and identifying baseline behavior',
      'Recognizing pre-incident indicators',
      'Understanding threat assessment levels',
      'Avoiding dangerous situations before they escalate',
      'Developing a personal safety mindset',
    ]}
  />

  <ProcessTimeline
    eyebrow="Awareness Levels"
    title="The Awareness Spectrum"
    steps={[
      {
        number: '01',
        title: 'Unaware',
        description: 'Distracted, unprepared, and unaware of your surroundings. This is where most people spend their time — and where danger finds them.',
        icon: '😶',
      },
      {
        number: '02',
        title: 'Aware',
        description: 'Relaxed but alert. You notice people, exits, and your environment without being stressed. This is where we train you to live.',
        icon: '👀',
      },
      {
        number: '03',
        title: 'Alert',
        description: 'Something has caught your attention. You shift focus, assess the situation, and begin forming a plan.',
        icon: '⚡',
      },
      {
        number: '04',
        title: 'Ready',
        description: 'A specific threat has been identified. You are prepared to act — whether that means leaving, de-escalating, or defending.',
        icon: '🛡️',
      },
    ]}
  />

  <SplitSection
    eyebrow="Everyday Preparedness"
    title="Skills You'll Use Every Day"
    description="Situational awareness isn't just for emergencies — it's a daily practice that makes you more confident in parking lots, grocery stores, while traveling, and anywhere you go. This class is designed for women of all experience levels."
    image="/images/team-partnership.jpg"
    imageAlt="Valkyrie Arms Training team"
    reversed={true}
  />

  <div class="section container">
    <div class="reveal" style="text-align: center; max-width: 600px; margin: 0 auto;">
      <span class="eyebrow">Pricing & Schedule</span>
      <h2>Ready to Get Started?</h2>
      <p style="color: var(--pwp-color-text-secondary); line-height: var(--pwp-line-height-relaxed);">
        Contact us for current pricing and upcoming class dates. Classes are available in Meridian and the surrounding Treasure Valley area, including Boise, Eagle, Nampa, Kuna, and Caldwell.
      </p>
    </div>
  </div>

  <LeadCapture
    eyebrow="Enroll Today"
    title="Sign Up for Situational Awareness"
    description="Fill out the form below and we'll get back to you with available class dates and all the details you need."
  />
</BaseLayout>
