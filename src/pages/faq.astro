---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FAQ from '../components/FAQ.astro';
import LeadCapture from '../components/LeadCapture.astro';

const faqItems = [
  {
    question: "I've never touched a firearm before. Is this class for me?",
    answer: "Absolutely. Many of our students have little to no prior experience. Our classes are designed to meet you exactly where you are — whether that's never having held a firearm or having some basic familiarity. We start with the fundamentals and build from there in a supportive, judgment-free environment.",
  },
  {
    question: "I'm nervous or intimidated. What if I don't know anything?",
    answer: "You're exactly who we designed Valkyrie for. We understand that stepping into something new — especially something involving firearms — can feel overwhelming. Our instructors are patient, encouraging, and create a space where every question is welcomed. You are not alone, and you will never be judged.",
  },
  {
    question: "Do I have to own a firearm to take a class?",
    answer: "Not at all. Valkyrie is about preparedness in all its forms — not just firearms. While we do offer firearms training, our mission is to help women feel confident and capable in all areas of personal safety and preparedness. You do not need to own a firearm to participate in our classes.",
  },
  {
    question: "I have physical limitations or mobility concerns. Can I still participate?",
    answer: "Yes. Every woman deserves access to quality training regardless of physical ability. We adapt our instruction to meet your needs and ensure you can participate fully and comfortably. Let us know about any accommodations when you sign up, and we'll make it work.",
  },
  {
    question: "I've been shooting with my husband, family, or friends for years. Will I still learn something?",
    answer: "Absolutely. We welcome students of all experience levels. Even seasoned shooters discover new techniques, refine their fundamentals, and gain confidence they didn't know they were missing. Our women-focused approach often reveals insights that traditional training environments overlook.",
  },
];
---

<BaseLayout
  title="Frequently Asked Questions"
  description="Frequently asked questions about Valkyrie Arms Training — women's firearms and self-defense training in Meridian, Idaho. Learn about our classes, requirements, and approach."
>
  <!-- Hero -->
  <Hero
    variant="minimal"
    eyebrow="Got Questions?"
    title="Frequently Asked Questions"
    description="We know stepping into something new can bring a lot of questions. Here are the ones we hear most — and if yours isn't listed, we'd love to hear from you."
  />

  <!-- FAQ Component -->
  <section class="section">
    <div class="container">
      <FAQ
        items={faqItems}
        showSchema={true}
      />
    </div>
  </section>

  <!-- Still Have Questions -->
  <section class="section still-questions">
    <div class="container">
      <div class="still-questions-inner reveal">
        <span class="eyebrow">Still Have Questions?</span>
        <h2>We're Here to Help</h2>
        <p class="section-subheading">Don't see your question above? We'd love to hear from you. Reach out by phone, email, or use the form below and we'll get back to you as soon as possible.</p>
        <div class="contact-quick">
          <a href="tel:208-815-8592" class="btn btn-ghost">📞 Call CheRee: 208-815-8592</a>
          <a href="tel:208-813-8780" class="btn btn-ghost">📞 Call Dez: 208-813-8780</a>
          <a href="mailto:info@valkyriearmstraining.com" class="btn btn-secondary">✉️ Email Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Lead Capture -->
  <LeadCapture
    eyebrow="Ask Us Anything"
    title="Send Us Your Question"
    description="Can't find the answer you're looking for? Use the form below and we'll personally get back to you."
  />
</BaseLayout>

<style>
  .still-questions {
    background: var(--pwp-color-background-elevated);
    border-top: 1px solid var(--pwp-color-border-subtle);
    border-bottom: 1px solid var(--pwp-color-border-subtle);
  }

  .still-questions-inner {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--pwp-space-4);
  }

  .still-questions-inner h2 {
    font-size: var(--pwp-font-size-3xl);
  }

  .still-questions-inner .section-subheading {
    text-align: center;
  }

  .contact-quick {
    display: flex;
    flex-wrap: wrap;
    gap: var(--pwp-space-4);
    margin-top: var(--pwp-space-4);
    justify-content: center;
  }
</style>
