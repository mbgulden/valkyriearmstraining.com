  "shadow": {
    "sm": { "$value": "0 2px 8px rgba(0, 0, 0, 0.15)", "$type": "shadow" },
    "md": { "$value": "0 4px 16px rgba(0, 0, 0, 0.2)", "$type": "shadow" },
    "lg": { "$value": "0 8px 32px rgba(0, 0, 0, 0.3)", "$type": "shadow" },
